# PostgreSQL
DATABASE_URL=postgresql+asyncpg://haccp:haccp_dev_password@localhost:5432/haccp_db
DATABASE_URL_SYNC=postgresql://haccp:haccp_dev_password@localhost:5432/haccp_db

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=regulatory_docs

# LLM (OpenRouter — OpenAI-compatible API)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=z-ai/glm-5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embeddings (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# LangSmith (optional observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=haccp-ai-system

# FastAPI
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Next.js (for frontend - Phase 1)
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000
AGENT_API_URL=http://localhost:8000
